{
  "mcpServers": {
    "browserbase": {
      "type": "stdio",
      "command": "dotenvx",
      "args": [
        "run",
        "-f", "/media/sam/1TB/.env",
        "--",
        "npx",
        "-y",
        "@browserbasehq/mcp-server-browserbase"
      ],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"],
      "env": {}
    },
    "chrome-mcp-server": {
      "type": "http",
      "url": "http://127.0.0.1:12306/mcp"
    }
  }
}
